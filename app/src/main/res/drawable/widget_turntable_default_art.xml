<?xml version="1.0" encoding="utf-8"?>
<!-- Default circular art for turntable widget preview -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Circular gradient background -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#283A4D"
                android:centerColor="#405571"
                android:endColor="#6B8099"
                android:type="linear" />
        </shape>
    </item>
    <!-- Circular red logo background -->
    <item
        android:width="140dp"
        android:height="140dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#EA3829" />
        </shape>
    </item>
    <!-- Centered app icon -->
    <item
        android:width="140dp"
        android:height="140dp"
        android:drawable="@drawable/ic_launcher_nobg"
        android:gravity="center" />
</layer-list>
